# PROJECT_elements .gitignore
# 4-Zone Architecture: only Zone 1 (Source Code) and Zone 2 (Reference Data) are tracked.
# Zone 3 (Generated Output) and Zone 4 (Ephemeral State) are gitignored.
#
# Zones:
#   1. Source Code    — particle/src/, wave/tools/, tests/, CI configs
#   2. Reference Data — particle/data/atoms/, wave/config/, standard-model-of-code/
#   3. Generated Output — research/, reports/, observer/, .collider/
#   4. Ephemeral State — .agent/state/, logs/, caches

# =============================================================================
# ZONE 3: GENERATED OUTPUT (regenerable, backed up to GCS)
# =============================================================================

# Archive (offloaded to GCS: gs://elements-archive-2026/)
archive/

# Research artifacts (AI research sessions, gemini dumps, extracted data)
research/
**/research/raw/
**/research/sessions/
**/research/extracted_nodes/
**/research/gemini/sessions/
**/research/gemini/raw/
particle/docs/research/

# Generated reports and analysis
reports/

# Observer analysis artifacts
observer/

# Wave library (agent cuts, large outputs)
wave/library/

# UI corpus data
particle/docs/ui/corpus/

# NotebookLM exports
notebook-lm/

# REH outputs
.reh/

# Collider outputs (all variants)
.collider/
.collider_*/
.collider-*/
.collider-full/
collider_feedback/
particle/collider_feedback/
standard-model-of-code/.collider/
standard-model-of-code/.collider_*/
standard-model-of-code/.collider-*/
standard-model-of-code/collider
standard-model-of-code/collider_output/

# Generated output directories
output/
logs/
particle/graphrag_out/

# Collider pipeline vendor libs (bundled in HTML reports)
**/collider_pipeline_files/
**/libs/bootstrap/
**/libs/quarto-html/
**/libs/clipboard/

# Generated text output files
*_output.txt
enriched_history.txt
unified_analysis.json

# Context management generated data
context-management/intelligence/socratic_audit_pipeline_*.json
**/socratic_audit_pipeline_*.json
context-management/data/intel/spiral/file_intel.json
context-management/data/intel/file_intel_cache.json

# Large generated reports
wave/library/large_outputs/

# Downloaded repos (benchmark targets)
**/repos/
**/artifacts/**/repos/
context-management/library/spectrometer_benchmarks_legacy/axios/
context-management/library/spectrometer_benchmarks_legacy/lodash/
archive/spectrometer_benchmarks_legacy/express/

# Tool-generated inventories
tools/*.csv

# Large reference files (stored in GCS)
swebok-v4.pdf
SMC_THEORY_COMPLETE*.zip

# =============================================================================
# ZONE 4: EPHEMERAL STATE (per-session, never committed)
# =============================================================================

# Agent runtime state (regenerated per session)
.agent/state/
.agent/macros/trigger_state*.yaml
.agent/macros/logs/
.agent/intelligence/autopilot_logs/
.agent/intelligence/confidence_reports/
.agent/intelligence/tdj.jsonl

# Stale archive snapshots
.archive-*/

# Trash
.file_explorer_trash/

# Claude Code worktrees
.claude/worktrees/

# Temporary verification outputs
.tmp_*/
**/.tmp_*/
tmp_*

# Scratch notes
ORGANIZED

# External tool data
.minimax/

# =============================================================================
# STANDARD: PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
venv_*/
.tools_venv/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# STANDARD: NODE.JS
# =============================================================================
node_modules/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# STANDARD: IDE & EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# STANDARD: OS FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# =============================================================================
# STANDARD: SECRETS (never commit)
# =============================================================================
.env
.env.local
*.pem
*.key

# =============================================================================
# STANDARD: BUILD OUTPUTS
# =============================================================================
dist/
build/
!particle/src/core/viz/build/
*.whl

# =============================================================================
# STANDARD: EVALUATIONS & OBSIDIAN
# =============================================================================
.eval/active/
*-Evaluation/
*-Evaluation.zip
.obsidian/

# =============================================================================
# STANDARD: ASSETS (user uploads, vendored JS)
# =============================================================================
assets/
!particle/src/core/viz/assets/
particle/src/core/viz/assets/vendor/

# =============================================================================
# STANDARD: TEMPORARY & BACKUP
# =============================================================================
*.tmp
*.bak
*.backup
backup_*.zip
*.log

# Claude Code workspace state
.claude/launch.json
.superpowers/

# Large binary documents (use git-lfs or store externally)
*.docx
