# PROJECT_elements .gitignore
# Seamless Enforcement: These patterns are NEVER committed

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
venv_*/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# NODE.JS
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE & EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# =============================================================================
# EVALUATIONS (downloaded tools for testing)
# =============================================================================
.eval/active/
*-Evaluation/
*-Evaluation.zip

# =============================================================================
# TEMPORARY & BACKUP
# =============================================================================
tmp_*
*.tmp
*.bak
*.backup
backup_*.zip
*.log

# =============================================================================
# SECRETS (never commit)
# =============================================================================
.env
.env.local
*.pem
*.key

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
dist/
build/
!particle/src/core/viz/build/
*.whl

# =============================================================================
# OBSIDIAN (optional - remove if you use Obsidian here)
# =============================================================================
.obsidian/

# =============================================================================
# ARCHIVE (offloaded to GCS: gs://elements-archive-2026/)
# =============================================================================
archive/
standard-model-of-code/collider_output/

# Context Management Logs
**/socratic_audit_pipeline_*.json
context-management/intelligence/socratic_audit_pipeline_*.json

# =============================================================================
# COLLIDER OUTPUTS (test directories)
# =============================================================================
# Collider artifacts (all output directories)
.collider/
.collider_*/
.collider-*/
standard-model-of-code/.collider/
standard-model-of-code/.collider_*/
standard-model-of-code/.collider-*/
standard-model-of-code/collider

# Vendor libraries (bundled in HTML reports)
**/collider_pipeline_files/
**/libs/bootstrap/
**/libs/quarto-html/
**/libs/clipboard/

# Temporary verification outputs
.tmp_*/
**/.tmp_*/

# =============================================================================
# RESEARCH ARTIFACTS (downloaded repos and generated data)
# =============================================================================
**/repos/
**/artifacts/**/repos/
**/research/extracted_nodes/

# =============================================================================
# TOOLS VIRTUAL ENVIRONMENT
# =============================================================================
.tools_venv/

# =============================================================================
# USER UPLOADS (PDFs, images, etc.)
# =============================================================================
assets/
!particle/src/core/viz/assets/

# =============================================================================
# AGENT SESSION STATE (ephemeral, not committed)
# =============================================================================
.agent/state/session.yaml
# TDJ generated data (recreate with: python tdj.py --scan)
.agent/intelligence/tdj.jsonl
unified_analysis.json
archive/spectrometer_benchmarks_legacy/express/
.collider-full/
# Large intel caches (regenerate with cerebras_spiral_intel.py)
context-management/data/intel/spiral/file_intel.json
context-management/data/intel/file_intel_cache.json
# Embedded git repos (benchmarks)
context-management/library/spectrometer_benchmarks_legacy/axios/
context-management/library/spectrometer_benchmarks_legacy/lodash/

# =============================================================================
# CONSOLIDATION PATTERNS (2026-01-31)
# Added by TASK-100 / BATCH-CONSOLIDATION-2026-01-31
# =============================================================================

# Research ephemeral data (keep docs/, ignore raw/ and sessions/)
**/research/raw/
**/research/sessions/

# Agent ephemeral outputs (regenerated per session)
.agent/intelligence/autopilot_logs/
.agent/intelligence/confidence_reports/
.agent/macros/logs/

# Tool-generated inventories (regenerate with generate_file_inventory.py)
tools/*.csv

# Large reference files (stored in gs://elements-archive-2026/large-files/)
swebok-v4.pdf
SMC_THEORY_COMPLETE*.zip
